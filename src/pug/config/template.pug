block config
	-let currentPage 		= 'home'
	-let content 			= 'My Page'
	-let siteName 			= 'GulpBoilerplate'
	-let pageDescription 	= 'Here is the description Page.'
	-let siteUrl 			= 'https://kikeestradadev.github.io/kikeestradadev'
	-let ogImage 			= siteUrl + '/images/icon_1024.png'
	-let ogTitle 			= siteName + ' - ' + content
doctype html
html(lang='en' prefix='og: http://ogp.me/ns#', class='no-js')
	head
		meta(charset="utf-8")
		meta(name="description", content=pageDescription)
		meta(name="viewport" content="width=device-width, initial-scale=1.0")
		meta(name="keywords", content="Frontend Architect, Technical Leader, Engineering Leadership, Frontend Architecture, Scalable Systems, React, TypeScript, Next.js, Remix, Design Systems, Accessibility, WCAG, Core Web Vitals, Performance Optimization, Headless CMS, Strapi, WordPress, Team Mentoring, Cross-functional Collaboration, Agile, Scrum")
		meta(property="og:title", content=ogTitle)
		meta(property="og:description", content=pageDescription)
		meta(property="og:type", content="website")
		meta(property="og:url", content=siteUrl + '/')
		meta(property="og:site_name", content=siteName)
		meta(property="og:locale", content="en_US")
		meta(property="og:image", content=ogImage)
		meta(property="og:image:width", content="1024")
		meta(property="og:image:height", content="1024")
		meta(property="og:image:alt", content=ogTitle)
		meta(name="twitter:card", content="summary_large_image")
		meta(name="twitter:title", content=ogTitle)
		meta(name="twitter:description", content=pageDescription)
		meta(name="twitter:image", content=ogImage)
		meta(name="twitter:image:alt", content=ogTitle)
		link(rel="canonical", href=siteUrl + '/')
		meta(name="apple-mobile-web-app-status-bar-style", content="default")
		meta(name="format-detection", content="telephone=no")
		link(rel="shortcut icon", type="image/png", href="images/icon_192.png")
		link(rel="icon", type="image/png", sizes="192x192", href="images/icon_192.png")
		link(rel="apple-touch-icon", sizes="192x192", href="images/icon_192.png")
		link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css")
		link(rel="preconnect" href="https://fonts.googleapis.com")
		link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
		link(href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet")
		link(rel="stylesheet" href="./tailwind-dist.css")
		title= currentPage.slice(0,1).toUpperCase() + currentPage.slice(1) + " | " + siteName
	body(class=`${currentPage} bg-gradient-to-br from-blue-50 via-indigo-50/30 to-purple-50/20 flex flex-col min-h-screen`, itemscope itemtype="http://schema.org/WebPage")
		//- here start the Main Header
		header(class='w-full flex flex-col bg-[var(--base-color)] border-b border-white/10 shadow-sm')
			block main-header
		//- here ends the Main Header
		//- here start the Main Container
		main(class='flex-1')
			block main-container 
		//- here ends the Main Container
		//- here start the Main Footer
		footer(class='mt-auto bg-white')
			block main-footer
		//- here ends the Main Footer
		script(src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js")
		script(src="/assets/index-dist.js")
		block scripts
