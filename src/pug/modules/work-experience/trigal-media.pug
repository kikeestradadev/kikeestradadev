//- Trigal Media
include ../../mixins/employment-date
div
	div(class="bg-gradient-to-br from-white via-blue-50/30 to-indigo-50/20 rounded-xl shadow-lg ring-1 ring-[var(--base-color)]/10 p-6 lg:p-8 border-l-4 border-[var(--base-color)] hover:shadow-2xl transition-shadow duration-300 group backdrop-blur-sm")
		div(class="flex flex-col m:flex-row m:items-start m:justify-between mb-4 gap-3")
			div(class="flex-1")
				h3(class="text-xl lg:text-2xl font-bold text-gray-900 group-hover:text-[var(--base-color)] transition-colors") Trigal Media
				h4(class="text-lg font-semibold text-[var(--base-color)] mb-3") Senior Web Developer Lead
			div(class="flex-shrink-0")
				+employmentDate('Sep 2025 - Current', '9 mos')
		div(class="space-y-4")
			div
				p(class="text-sm font-semibold text-[var(--base-color)] uppercase tracking-wide mb-2") Role Overview
				p(class="text-gray-700 leading-relaxed text-base")
					| Lead frontend architecture for a 10-person engineering team building AI-assisted MVPs across legal, healthcare, education, and SMB ecommerce — making technical decisions on React, Next.js, WordPress, Laravel, and RAG integrations while keeping platforms scalable and maintainable.
			div(class="space-y-3")
				p(class="text-sm font-semibold text-[var(--base-color)] uppercase tracking-wide mb-2") Key Achievements
				ul(class="space-y-2.5 list-none text-gray-700 text-base")
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Reduced estimated 12-month MVP timelines to approximately 6 months through AI-assisted development workflows
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Lead frontend architecture for a 10-person engineering team across product, design, and engineering delivery
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Designed reusable frontend architecture patterns that shortened setup time for new product MVPs
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Established engineering standards, code review practices, and mentoring routines that improved team consistency
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Defined frontend architecture across React, Next.js, WordPress, Laravel, and RAG-based AI integrations
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Coordinated product, design, and engineering teams while owning frontend architecture and technical execution
			p(class="text-sm text-gray-700 mt-5 pt-4 border-t border-gray-100")
				span(class="font-semibold text-[var(--base-color)]") Stack:
				|  React · Next.js · Astro · TypeScript · WordPress · Laravel · AI APIs · RAG
