//- Trigal Media
include ../../mixins/employment-date
include ../../mixins/stack-badges
div
	div(class="bg-gradient-to-br from-white via-blue-50/30 to-indigo-50/20 rounded-xl shadow-lg ring-1 ring-[var(--base-color)]/10 p-6 lg:p-8 border-l-4 border-[var(--base-color)] hover:shadow-2xl transition-shadow duration-300 group backdrop-blur-sm")
		div(class="flex flex-col m:flex-row m:items-start m:justify-between mb-4 gap-3")
			div(class="flex-1")
				h3(class="text-xl lg:text-2xl font-bold text-gray-900 group-hover:text-[var(--base-color)] transition-colors") Trigal Media
				div(class="flex flex-wrap gap-1.5 mb-2")
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") AI-Assisted Product Development
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") RAG Integrations
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") Freelance / Part-time
				h4(class="text-lg font-semibold text-[var(--base-color)] mb-3") Senior Web Developer Lead (Freelance / Part-time)
			div(class="flex-shrink-0")
				+employmentDate('Sep 2025 - Current', '9 mos')
		div(class="space-y-4")
			div
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Role Overview
				p(class="text-gray-700 leading-relaxed text-base")
					| Freelance frontend technical lead for a Costa Rica–based startup focused on AI-powered MVPs across legal, healthcare, education, and SMB verticals. I provide architecture direction, code reviews, and hands-on development with React, Next.js, Astro, and TypeScript — supporting AI API and RAG integrations on a project basis.
			div
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Key Project — AI-Assisted Product Development
				p(class="text-gray-700 leading-relaxed text-base")
					| Clients needed practical MVPs with AI capabilities across legal, healthcare, education, and SMB use cases — with a small, junior-heavy team and tight cycles. I provide frontend architecture and hands-on delivery with React, Next.js, Astro, TypeScript, and RAG-based workflows, establishing reusable patterns and code review standards that support faster MVP delivery and maintainable AI-enabled product foundations.
			div(class="space-y-3")
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Key Achievements
				ul(class="space-y-2.5 list-none text-gray-700 text-base")
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Provide frontend architecture guidance on a freelance basis for AI-assisted MVPs across legal, healthcare, education, and SMB product initiatives
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Support integration of AI APIs and RAG workflows into user-facing applications with maintainable, production-ready frontend patterns
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Apply AI-assisted development workflows (Cursor, Claude, ChatGPT) during focused project engagements to accelerate debugging, prototyping, and documentation
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Mentor junior developers during project engagements through code reviews, pairing, and practical frontend standards
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Collaborate with product and design stakeholders on scoped frontend execution plans when projects are active
			+stackBadges(['React', 'Next.js', 'Astro', 'TypeScript', 'WordPress', 'Laravel', 'AI APIs', 'RAG', 'AI-Assisted Development'])
