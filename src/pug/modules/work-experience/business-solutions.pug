//- Gambling Industry
include ../../mixins/employment-date
include ../../mixins/stack-badges
div
	div(class="bg-gradient-to-br from-white to-gray-50/50 rounded-xl shadow-lg ring-1 ring-[var(--base-color)]/10 p-6 lg:p-8 border-l-4 border-[var(--base-color)] hover:shadow-2xl transition-shadow duration-300 group backdrop-blur-sm")
		div(class="flex flex-col m:flex-row m:items-start m:justify-between mb-4 gap-3")
			div(class="flex-1")
				h3(class="text-xl lg:text-2xl font-bold text-gray-900 group-hover:text-[var(--base-color)] transition-colors mb-2") JazzSports / MyBookie
				div(class="flex flex-wrap gap-1.5 mb-2")
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") JazzSports
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") MyBookie
				h4(class="text-lg font-semibold text-[var(--base-color)] mb-3") Technical Lead Manager
			div(class="flex-shrink-0")
				+employmentDate('Sep 2015 - Dec 2019', '4 yrs 3 mos')
		div(class="space-y-4")
			div
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Role Overview
				p(class="text-gray-700 leading-relaxed text-base")
					| Technical Lead Manager for 25 designers and developers across two teams at a high-traffic sportsbook and casino company — responsible for hiring, mentoring, frontend architecture ownership, and delivery across WordPress, PHP, .NET, and multi-brand marketing properties within the iGaming industry.
			div(class="space-y-3")
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Key Achievements
				ul(class="space-y-2.5 list-none text-gray-700 text-base")
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Led 25 designers and developers across two teams, with responsibility for hiring, technical direction, code quality, and delivery schedules
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Managed 40+ major projects across casino, sportsbook, email, and commercial brand properties
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Reduced production delivery time by approximately 50% through clearer sprint planning, code review standards, and Agile workflow improvements
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Contributed to client base growth through an SEO-focused WordPress strategy and more reliable delivery across sportsbook and casino properties
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Mentored developers and trained UX/UI teams on HTML, responsive patterns, and front-end best practices
			+stackBadges(['WordPress', 'PHP', '.NET', 'JavaScript', 'SEO', 'Email & banner production'])