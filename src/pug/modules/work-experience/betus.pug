//- Gambling Industry
include ../../mixins/employment-date
div
	div(class="bg-gradient-to-br from-white via-blue-50/30 to-indigo-50/20 rounded-xl shadow-lg ring-1 ring-[var(--base-color)]/10 p-6 lg:p-8 border-l-4 border-[var(--base-color)] hover:shadow-2xl transition-shadow duration-300 group backdrop-blur-sm")
		div(class="flex flex-col m:flex-row m:items-start m:justify-between mb-4 gap-3")
			div(class="flex-1")
				h3(class="text-xl lg:text-2xl font-bold text-gray-900 group-hover:text-[var(--base-color)] transition-colors mb-2") Gambling Industry
				div(class="flex flex-wrap gap-1.5 mb-2")
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") BetUS
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") BetAnything
				h4(class="text-lg font-semibold text-[var(--base-color)] mb-3") Senior Web Developer Lead
			div(class="flex-shrink-0")
				+employmentDate('Mar 2023 - Aug 2025', '2 yrs 6 mos')
		div(class="space-y-4")
			div
				p(class="text-sm font-semibold text-[var(--base-color)] uppercase tracking-wide mb-2") Role Overview
				p(class="text-gray-700 leading-relaxed text-base")
					| Owned frontend architecture and technical leadership across BetUs and BetAnything properties for more than two years — covering WordPress platforms, sports media sites, affiliate properties, and BetAnything.eu on React, Remix, and Strapi in a multi-brand sportsbook environment.
			div(class="space-y-3")
				p(class="text-sm font-semibold text-[var(--base-color)] uppercase tracking-wide mb-2") Key Achievements
				ul(class="space-y-2.5 list-none text-gray-700 text-base")
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Completed a planned 12-month platform rebrand and migration in 6 months — delivering in 50% of the planned timeline
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Defined frontend architecture for BetAnything.eu on React, Remix, and Strapi for a high-traffic sportsbook platform
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Delivered 10+ custom WordPress themes and resolved complex implementations the team had previously been unable to ship
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Improved Core Web Vitals, maintainability, and content publishing through reusable components and clearer frontend patterns
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Established Jest, React Testing Library, and Cypress standards that reduced production defects before release
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Significantly improved team output through architecture standards, hands-on training, and developer mentoring
			p(class="text-sm text-gray-700 mt-5 pt-4 border-t border-gray-100")
				span(class="font-semibold text-[var(--base-color)]") Stack:
				|  React · Remix · TypeScript · WordPress · PHP · Laravel · Strapi · Jest · Cypress
		div(class="mt-3 pt-3 border-t border-gray-200 flex flex-col gap-2")
			span(class="text-sm font-semibold text-[var(--base-color)]") References: 
			span(class="text-sm text-gray-600") Patricio Espinoza: CMO · 
				a(href="tel:+50688641972" class="text-[var(--base-color)] hover:text-blue-600") (+506) 8864-1972
			span(class="text-sm text-gray-600") Patricio Garcia: Creative Director · 
				a(href="tel:+50660406018" class="text-[var(--base-color)] hover:text-blue-600") (+506) 6040-6018
