//- Accenture
include ../../mixins/employment-date
include ../../mixins/stack-badges
div
	div(class="bg-gradient-to-br from-white to-gray-50/50 rounded-xl shadow-lg ring-1 ring-[var(--base-color)]/10 p-6 lg:p-8 border-l-4 border-[var(--base-color)] hover:shadow-2xl transition-shadow duration-300 group backdrop-blur-sm")
		div(class="flex flex-col m:flex-row m:items-start m:justify-between mb-4 gap-3")
			div(class="flex-1")
				h3(class="text-xl lg:text-2xl font-bold text-gray-900 group-hover:text-[var(--base-color)] transition-colors mb-2") Accenture
				div(class="flex flex-wrap gap-1.5 mb-2")
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") Citi
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") Wells Fargo
					span(class="text-[11px] px-2 py-0.5 rounded bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-[var(--base-color)] font-semibold") Salesforce Marketing Cloud
				h4(class="text-lg font-semibold text-[var(--base-color)] mb-3") Web Developer Senior Analyst
			div(class="flex-shrink-0")
				+employmentDate('Jul 2020 - Jul 2021', '1 yr')
		div(class="space-y-4")
			div
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Role Overview
				p(class="text-gray-700 leading-relaxed text-base")
					| Supported enterprise marketing operations for major U.S. banking clients including Citi and Wells Fargo on a 15-person team — contributing frontend architecture decisions and compliance-sensitive email delivery through Salesforce Marketing Cloud.
			div(class="space-y-3")
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Key Achievements
				ul(class="space-y-2.5 list-none text-gray-700 text-base")
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Supported enterprise email programs for Citi, Wells Fargo, and other U.S. banking clients through compliance-sensitive Salesforce Marketing Cloud operations
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold shrink-0") •
						span(class="font-semibold text-gray-900 leading-snug") Built a Node.js component-driven email bundle that substantially increased team campaign output and reduced repetitive build work
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Standardized campaign workflows to improve cross-client compatibility and QA turnaround across concurrent programs
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Mentored junior developers and trained cross-department teams on Marketing Cloud workflows, supporting engineering standards and cross-functional collaboration
			+stackBadges(['Salesforce Marketing Cloud', 'AMPscript', 'HTML', 'CSS', 'JavaScript', 'Node.js'])