//- Experian Marketing Services
include ../../mixins/employment-date
include ../../mixins/stack-badges
div
	div(class="bg-gradient-to-br from-white to-gray-50/50 rounded-xl shadow-lg ring-1 ring-[var(--base-color)]/10 p-6 lg:p-8 border-l-4 border-[var(--base-color)] hover:shadow-2xl transition-shadow duration-300 group backdrop-blur-sm")
		div(class="flex flex-col m:flex-row m:items-start m:justify-between mb-4 gap-3")
			div(class="flex-1")
				h3(class="text-xl lg:text-2xl font-bold text-gray-900 group-hover:text-[var(--base-color)] transition-colors mb-2") Experian Marketing Services
				h4(class="text-lg font-semibold text-[var(--base-color)] mb-3") Front End and Email Developer
			div(class="flex-shrink-0")
				+employmentDate('Aug 2012 - Oct 2015', '3 yrs 2 mos')
		div(class="space-y-4")
			div
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Role Overview
				p(class="text-gray-700 leading-relaxed text-base")
					| Front-end and email developer on a 10-person enterprise marketing team — contributed to reusable template architecture, onboarding, and QA practices for high-volume HTML campaigns, landing pages, and forms on Experian's proprietary platform.
			div(class="space-y-3")
				p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Key Achievements
				ul(class="space-y-2.5 list-none text-gray-700 text-base")
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Substantially increased campaign output through reusable templates, components, and standardized development workflows
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Created a training program for new developers on proprietary campaign workflows, reducing onboarding time for incoming team members
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Reduced rework by improving cross-client QA checks and brand-standard review before handoff
					li(class="flex items-start gap-2")
						span(class="text-[var(--base-color)] font-bold") •
						span Supported high-volume email and web campaigns for beauty, retail, and enterprise clients (confidential)
			+stackBadges(['HTML', 'CSS', 'JavaScript', 'Email Development', 'A/B Testing', 'Cross-client QA'])
