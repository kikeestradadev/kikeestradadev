-
	const skillCategories = [
		{
			title: 'Frontend Development',
			items: ['React', 'TypeScript', 'Next.js', 'Remix', 'JavaScript', 'Astro', 'Tailwind CSS']
		},
		{
			title: 'CMS & Platforms',
			items: ['WordPress · Gutenberg', 'Headless CMS', 'Strapi']
		},
		{
			title: 'Frontend Architecture',
			items: ['SSR · SSG · ISR', 'Component libraries', 'Design systems', 'Scalable UI architecture', 'Micro frontends']
		},
		{
			title: 'AI-Assisted Development',
			items: ['Cursor', 'Claude', 'ChatGPT', 'AI-assisted debugging', 'prototyping', 'documentation workflows']
		},
		{
			title: 'Leadership & Collaboration',
			items: ['Technical leadership', 'Team leadership', 'Mentoring', 'Cross-functional collaboration', 'Agile · Scrum', 'Technical reviews & planning']
		},
		{
			title: 'Accessibility',
			items: ['WCAG 2.1 · ADA · Section 508', 'ARIA', 'Keyboard navigation', 'Focus management']
		},
		{
			title: 'Performance Optimization',
			items: ['Core Web Vitals', 'Code splitting', 'Lazy loading', 'Performance audits', 'Bundle optimization']
		},
		{
			title: 'Backend Integration',
			items: ['GraphQL', 'REST APIs', 'Laravel', 'Node.js']
		},
		{
			title: 'Testing',
			items: ['Jest', 'React Testing Library', 'Cypress', 'Unit & integration testing']
		},
		{
			title: 'State Management & Data',
			items: ['React Query · TanStack Query', 'Redux', 'Zustand', 'Context API', 'SWR']
		}
	]

div(class="main-container py-10 lg:py-12 bg-white" id="skills")
	div(class="container")
		div(class="mb-6 lg:mb-8 text-center")
			h2(class="text-3xl lg:text-4xl font-bold text-[var(--base-color)] mb-3 inline-block relative") Technical Skills
			div(class="w-24 h-1 bg-gradient-to-r from-[var(--base-color)] to-blue-600 rounded-full mx-auto")
		div(class="rounded-xl border border-gray-200/80 bg-slate-50/50 p-5 sm:p-6 lg:p-8")
			div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-5 lg:gap-y-6")
				each category in skillCategories
					div
						h3(class="text-sm font-bold text-[var(--base-color)] mb-1.5 leading-snug")= category.title
						p(class="text-sm text-gray-700 leading-relaxed")= category.items.join(' · ')
