//- Quick Facts — vertical metrics list (right column)
-
	const quickFactStats = [
		{ value: '14+', label: 'Years Experience' },
		{ value: '10+', label: 'Enterprise Platforms' },
		{ value: '10+', label: 'Developers Led' }
	]
	const quickFactIndustries = ['Gaming', 'SaaS', 'Healthcare', 'Banking', 'Ecommerce']

div(id="quick-facts" class="flex-1 w-full lg:flex")
	div(class="rounded-xl bg-white/10 backdrop-blur-sm border border-white/15 overflow-hidden w-full lg:h-full lg:flex lg:flex-col")
		div(class="px-4 py-2.5 lg:px-6 lg:py-3.5 border-b border-white/10")
			p(class="text-[11px] lg:text-sm uppercase tracking-wider text-white/60 font-semibold") At a Glance
		div(class="divide-y divide-white/10 lg:flex-1 lg:flex lg:flex-col lg:justify-center")
			each stat in quickFactStats
				div(class="flex items-center gap-3 lg:gap-5 px-4 py-3.5 lg:px-6 lg:py-6")
					p(class="text-2xl lg:text-4xl font-bold text-white leading-none w-12 lg:w-[4.5rem] shrink-0 tabular-nums")= stat.value
					p(class="text-sm lg:text-lg text-white/90 font-medium leading-snug")= stat.label
			div(class="px-4 py-3.5 lg:px-6 lg:py-6")
				p(class="text-sm lg:text-lg font-semibold text-white mb-2 lg:mb-3") Multi-Industry
				div(class="flex flex-wrap gap-1.5 lg:gap-2")
					each industry in quickFactIndustries
						span(class="px-2 py-0.5 lg:px-2.5 lg:py-1 rounded-md bg-white/10 border border-white/10 text-[11px] lg:text-sm text-white/85 font-medium")= industry
