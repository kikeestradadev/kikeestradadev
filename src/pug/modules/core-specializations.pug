-
	const specializations = [
		'React Ecosystem',
		'Frontend Architecture',
		'Technical Leadership',
		'AI-Assisted Development',
		'Enterprise Web Platforms',
		'Performance Optimization',
		'Accessibility & UX',
		'Headless CMS Solutions'
	]

div(class="main-container bg-white border-b border-gray-100" id="specializations")
	div(class="container py-6 lg:py-8")
		div(class="text-center")
			h2(class="text-xl lg:text-2xl font-bold text-[var(--base-color)] mb-2") Core Specializations
			div(class="w-16 h-0.5 bg-gradient-to-r from-[var(--base-color)] to-blue-600 rounded-full mx-auto mb-3")
			p(class="text-sm text-gray-600 max-w-2xl mx-auto mb-4") Focus areas where I combine hands-on delivery with technical leadership.
			div(class="flex flex-wrap justify-center gap-2")
				each item in specializations
					span(class="px-2.5 py-1 rounded-md bg-[var(--base-color)]/10 border border-[var(--base-color)]/15 text-xs sm:text-sm text-[var(--base-color)] font-medium")= item
