-
	const portfolioItems = [
		{
			title: 'Trigal Media',
			live: '',
			confidential: true,
			image: 'images/pf/pf_nextjs.png',
			role: 'Senior Web Developer Lead (Freelance / Part-time)',
			tech: 'React · Next.js · Astro · TypeScript · AI APIs · RAG',
			businessGoal: 'Help a startup deliver AI-powered MVPs across legal, healthcare, education, and SMB clients under NDA.',
			technicalSolution: 'Provide freelance frontend architecture, RAG integration support, and hands-on delivery with React, Next.js, Astro, and TypeScript.',
			outcome: 'Enabled practical MVP delivery through reusable patterns, mentoring, and maintainable AI-enabled frontend foundations.',
			src: ''
		},
		{
			title: 'BetAnySports',
			live: 'https://www.betanything.eu/',
			image: 'images/pf/bet.png',
			role: 'Senior Frontend Lead',
			tech: 'React + Remix + Strapi',
			businessGoal: 'Support a high-traffic, multi-brand sportsbook experience with a modern, maintainable frontend platform.',
			technicalSolution: 'Led frontend architecture using React, Remix, and Strapi with headless CMS integration and performance-focused delivery patterns.',
			outcome: 'Improved maintainability, publishing workflows, and scalable delivery for a production sportsbook property.',
			src: ''
		},
		{
			title: 'Insiders',
			live: 'https://insidersbettingdigest.com/',
			image: 'images/pf/insiders.png',
			role: 'Senior Frontend Lead',
			tech: 'WordPress',
			businessGoal: 'Scale SEO-driven sports media content across a multi-brand publishing property.',
			technicalSolution: 'Delivered custom WordPress architecture and responsive publishing workflows for editorial teams.',
			outcome: 'Improved editorial scalability and production-ready content delivery.',
			src: ''
		},
		{
			title: 'Crypto Tutorials',
			live: 'https://crypto-tutorials.com/',
			image: 'images/pf/crypto.png',
			role: 'Senior Frontend Lead',
			tech: 'React',
			businessGoal: 'Launch a content-focused marketing product with dynamic, API-driven information delivery.',
			technicalSolution: 'Built a React-based site with component architecture and API-driven dynamic content.',
			outcome: 'Delivered a production-ready marketing platform with scalable content delivery.',
			src: ''
		},
		{
			title: 'My Bookie',
			live: 'https://www.mybookie.ag/',
			image: 'images/pf/mb.png',
			role: 'Senior Frontend Lead',
			tech: 'WordPress · PHP · JavaScript',
			businessGoal: 'Maintain consistent, accessible frontend delivery across enterprise sportsbook properties.',
			technicalSolution: 'Contributed WordPress, PHP, and JavaScript frontend work within a multi-brand sportsbook ecosystem.',
			outcome: 'Supported accessibility-focused implementation and multi-brand consistency across high-traffic properties.',
			src: ''
		}
	]

div(class="main-container bg-gradient-to-br from-purple-50/40 via-pink-50/30 to-rose-50/20" id="portfolio")
	div(class="container py-12 lg:py-16")
		div(class="mb-12 text-center")
			h2(class="text-3xl lg:text-4xl font-bold text-[var(--base-color)] mb-3 inline-block relative") Portfolio
			div(class="w-24 h-1 bg-gradient-to-r from-[var(--base-color)] to-blue-600 rounded-full mx-auto")
		div(class="grid grid-cols-1 m:grid-cols-2 l:grid-cols-3 lg:grid-cols-4 gap-6")
			each item in portfolioItems
				- var hasLive = item.live && typeof item.live === 'string' && item.live.trim() !== '';
				- var hasSrc = item.src && typeof item.src === 'string' && item.src.trim() !== '';
				- var isConfidential = item.confidential === true;
				- var imageUrl = item.image || 'https://kikeestrada.github.io/kikeestradadev/assets/img/insiders.png';
				div(class="group block bg-gradient-to-br from-white via-purple-50/30 to-pink-50/20 rounded-xl shadow-lg overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-200/50 hover:border-[var(--base-color)]/50 backdrop-blur-sm")
					if hasLive
						a(href=item.live target="_blank" rel="noopener noreferrer" class="block relative overflow-hidden bg-gradient-to-br from-gray-100 to-gray-200 aspect-video cursor-pointer")
							img(src=imageUrl alt=item.title class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500")
							div(class="absolute inset-0 bg-gradient-to-br from-[var(--base-color)]/0 via-[var(--base-color)]/0 to-[var(--base-color)]/0 group-hover:from-[var(--base-color)]/10 group-hover:via-[var(--base-color)]/15 group-hover:to-[var(--base-color)]/20 transition-all duration-300")
					else
						div(class="block relative overflow-hidden bg-gradient-to-br from-gray-100 to-gray-200 aspect-video")
							img(src=imageUrl alt=item.title class="w-full h-full object-cover opacity-90")
							if isConfidential
								div(class="absolute inset-0 flex items-center justify-center bg-[var(--base-color)]/70 px-4")
									span(class="text-white text-sm font-semibold text-center") Confidential client work
					div(class="p-4 sm:p-5 bg-gradient-to-b from-transparent to-white/50")
						h3(class="text-base sm:text-lg font-bold mb-2 sm:mb-3 text-gray-900 group-hover:text-[var(--base-color)] transition-colors duration-300")= item.title
						if item.role || item.tech || item.businessGoal
							div(class="hidden sm:block space-y-2.5 mb-5")
								if item.role
									div(class="flex items-start gap-2")
										span(class="text-xs font-semibold text-[var(--base-color)] uppercase tracking-wide min-w-[72px]") Role:
										span(class="text-sm text-gray-700 font-medium")= item.role
								if item.tech
									div(class="flex items-start gap-2 flex-wrap")
										span(class="text-xs font-semibold text-[var(--base-color)] uppercase tracking-wide min-w-[72px]") Stack:
										span(class="text-sm text-gray-700 font-medium")= item.tech
								if item.businessGoal
									div(class="flex items-start gap-2")
										span(class="text-xs font-semibold text-[var(--base-color)] uppercase tracking-wide min-w-[72px] pt-0.5") Goal:
										span(class="text-sm text-gray-700 flex-1")= item.businessGoal
								if item.technicalSolution
									div(class="flex items-start gap-2")
										span(class="text-xs font-semibold text-[var(--base-color)] uppercase tracking-wide min-w-[72px] pt-0.5") Solution:
										span(class="text-sm text-gray-700 flex-1")= item.technicalSolution
								if item.outcome
									div(class="flex items-start gap-2")
										span(class="text-xs font-semibold text-[var(--base-color)] uppercase tracking-wide min-w-[72px] pt-0.5") Outcome:
										span(class="text-sm text-gray-700 flex-1")= item.outcome
						div(class="hidden sm:block mb-4 border-t border-gray-200")
						div(class="flex flex-col gap-2 sm:gap-2.5")
							if hasLive
								a(href=item.live target="_blank" rel="noopener noreferrer" class="flex items-center justify-between px-2.5 sm:px-3 py-2 sm:py-2.5 bg-gradient-to-r from-[var(--base-color)]/5 to-blue-500/5 hover:from-[var(--base-color)]/10 hover:to-blue-500/10 text-xs sm:text-sm text-gray-700 hover:text-[var(--base-color)] rounded-lg transition-all duration-300 border border-[var(--base-color)]/10 hover:border-[var(--base-color)]/30 group/link")
									span(class="font-medium") View Project
									svg(class="w-3.5 h-3.5 sm:w-4 sm:h-4 transform group-hover/link:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24")
										path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")
							else if isConfidential
								div(class="flex items-center justify-center px-2.5 sm:px-3 py-2 sm:py-2.5 bg-gray-100 text-xs sm:text-sm text-gray-600 rounded-lg border border-gray-200 font-medium") Confidential client work
							if hasSrc
								a(href=item.src target="_blank" rel="noopener noreferrer" class="flex items-center justify-between px-2.5 sm:px-3 py-2 sm:py-2.5 bg-gradient-to-r from-gray-100 to-gray-50 hover:from-gray-200 hover:to-gray-100 text-xs sm:text-sm text-gray-600 hover:text-gray-900 rounded-lg transition-all duration-300 border border-gray-200 hover:border-gray-300 group/src")
									span(class="font-medium") View Source Code
									svg(class="w-3.5 h-3.5 sm:w-4 sm:h-4 transform group-hover/src:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24")
										path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4")
