div(class="main-container bg-gradient-to-br from-indigo-50/30 via-blue-50/20 to-white" id="industries")
	div(class="container py-10 lg:py-12")
		div(class="mb-8 text-center")
			h2(class="text-3xl lg:text-4xl font-bold text-[var(--base-color)] mb-3 inline-block relative") Industries
			div(class="w-24 h-1 bg-gradient-to-r from-[var(--base-color)] to-blue-600 rounded-full mx-auto")
			p(class="text-gray-600 mt-4 max-w-2xl mx-auto text-base") Domain experience across regulated, high-traffic, and product-led digital environments.
		div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6")
			each industry in industries
				div(class="group bg-white rounded-xl shadow-md p-5 lg:p-6 border border-gray-200/80 border-l-4 border-l-[var(--base-color)] hover:shadow-lg hover:border-[var(--base-color)]/30 transition-all duration-300")
