						div(class="shrink-0 w-11 h-11 rounded-lg bg-[var(--base-color)]/10 flex items-center justify-center group-hover:bg-[var(--base-color)]/15 transition-colors")
							svg(class="w-5 h-5 text-[var(--base-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24")
								path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d=industry.icon)
						div(class="min-w-0")
							p(class="text-base font-bold text-gray-900 leading-snug mb-1.5")= industry.name
							p(class="text-sm text-gray-600 leading-relaxed")= industry.tag
