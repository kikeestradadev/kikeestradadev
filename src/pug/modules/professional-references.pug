div(class="main-container bg-white border-t border-gray-100" id="references")
	div(class="container py-10 lg:py-14")
		div(class="mb-8 text-center")
			h2(class="text-3xl lg:text-4xl font-bold text-[var(--base-color)] mb-3 inline-block relative") Professional References
			div(class="w-24 h-1 bg-gradient-to-r from-[var(--base-color)] to-blue-600 rounded-full mx-auto")
			p(class="text-sm text-gray-600 mt-4 max-w-2xl mx-auto") Placeholders for future LinkedIn recommendations and client references. No testimonials are displayed until verified quotes are provided.
		div(class="grid grid-cols-1 lg:grid-cols-3 gap-6")
			each ref in referencePlaceholders
				div(class="rounded-xl shadow-md border-l-4 border-gray-300 bg-white p-6 lg:p-8 hover:shadow-lg transition-shadow duration-300")
					span(class="inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide bg-gray-100 text-gray-500 mb-4") Pending Reference
					blockquote(class="italic text-gray-500 text-sm leading-relaxed border-l-2 border-gray-200 pl-4 mb-4")= ref.quote
					div(class="space-y-1 text-sm text-gray-500")
						p
							span(class="font-semibold text-gray-600") Role:
							|  #{ref.role}
						p
							span(class="font-semibold text-gray-600") Company:
							|  #{ref.company}
					p(class="text-xs text-gray-400 mt-4 pt-3 border-t border-gray-100") Pending — LinkedIn recommendation
