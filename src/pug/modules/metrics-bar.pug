//- Unified hero metrics — Key Metrics + Impact Snapshot
section(class="metrics-block" aria-label="Key metrics and impact snapshot")
	p(class="metrics-section-label") Key Metrics
	div(class="metrics-top-grid")
		div(class="metric-card")
			p(class="metric-number") 18+
			p(class="metric-label") Years Experience
		div(class="metric-card")
			p(class="metric-number") 1M+
			p(class="metric-label") Monthly Users
		div(class="metric-card")
			p(class="metric-number") ~50%
			p(class="metric-label") Faster Delivery
		div(class="metric-card")
			p(class="metric-number") 40+
			p(class="metric-label") Major Projects
	div(class="metrics-divider")
	div(class="metrics-bottom-grid")
		div(class="metric-detail")
			p(class="metric-number-sm") ~50%
			p(class="metric-sublabel") Delivery & Pace
			p(class="metric-description") 12-month rebrand completed in 6 months
		div(class="metric-detail")
			p(class="metric-number-sm") 1M+
			p(class="metric-sublabel") Platform Scale
			p(class="metric-description") High-traffic platforms supporting 1M+ monthly users
		div(class="metric-detail")
			p(class="metric-number-sm") 25
			p(class="metric-sublabel") Leadership & People
			p(class="metric-description") Engineers led — mentoring and engineering standards
