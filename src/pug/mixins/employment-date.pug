//- Employment date pill with tenure duration
mixin employmentDate(dateRange, duration)
	span(class="inline-block px-4 py-2 bg-gradient-to-r from-[var(--base-color)]/10 to-blue-500/10 text-[var(--base-color)] text-sm font-semibold rounded-lg border border-[var(--base-color)]/20 text-center m:text-right")
		span(class="block whitespace-nowrap")= dateRange
		span(class="block text-[11px] font-medium text-gray-600 mt-0.5 whitespace-nowrap")= duration
