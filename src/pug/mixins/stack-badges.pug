//- Stack technology badges for work experience entries
mixin stackBadges(technologies)
	div(class="mt-5 pt-4 border-t border-gray-100")
		p(class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2") Stack
		div(class="flex flex-wrap gap-1")
			each tech in technologies
				span(class="inline-flex items-center bg-slate-100 text-slate-700 text-xs font-medium px-2 py-1 rounded")= tech
